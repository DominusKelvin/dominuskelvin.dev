---
import HeaderLink from './HeaderLink.astro'
---

<header class="border-b border-app-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-10 py-8 lg:py-12">
    <div class="text-center space-y-6">
      <div>
        <h1
          class="text-3xl sm:text-4xl lg:text-5xl font-bold text-app-text mb-2"
        >
          <a href="/" class="transition-colors hover:text-app-text-muted">
            Kelvin <span class="text-green-600">O</span> Omereshone
          </a>
        </h1>
        <p class="text-base sm:text-lg text-app-text-soft">
          Developer. Teacher. Speaker.
        </p>
      </div>
      <nav class="flex flex-wrap items-center justify-center gap-x-6 gap-y-3">
        <HeaderLink href="/blog">Blog</HeaderLink>
        <HeaderLink href="/music">Music</HeaderLink>
        <HeaderLink href="/articles">Articles</HeaderLink>
        <HeaderLink href="/books">Books</HeaderLink>
        <HeaderLink href="/tkyt">TKYT</HeaderLink>
      </nav>
    </div>
  </div>
</header>
