---
export interface Session {
  title: string
  teacher: string
  teacherUrl: string
  date: string
  poster: string
  url?: string
}
export interface Props {
  session: Session
}
const { session } = Astro.props
---

<div
  class="relative overflow-hidden rounded-xl bg-app-surface ring-1 ring-app-border"
>
  <a href={session.url} target="_blank"
    ><img
      class="font-semibold"
      width={1012}
      height={506}
      src={session.poster}
      alt={session.title}
      loading="lazy"
    />
  </a>
</div>
<h3 class="font-extrabold text-md text-purple-500">
  {session.title}
  <span> with</span>
  <a class="text-pink-600 underline" href={session.teacherUrl} target="_blank"
    >{session.teacher}
  </a>
</h3>
<p class="text-app-text-soft text-sm">
  {
    new Date(session.date).toLocaleDateString('en-us', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    })
  }
</p>
